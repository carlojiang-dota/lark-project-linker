{
  "manifest_version": 3,
  "version": "2.3.0",
  "name": "Lark Linker for GitLab & GitHub",
  "description": "Auto-convert project IDs in GitLab/GitHub to clickable Lark (Feishu/飞书) links. Supports story, issue and Sentry.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["index.js"]
    },
    {
      "matches": ["*://*/*"],
      "js": ["sentry.js"]
    }
  ],
  "options_page": "options.html"
}
